{
  "name": "hermes-starcraft-dashboard",
  "version": "1.0.0",
  "description": "Real-time 3D StarCraft dashboard for Hermes Agent — self-representing, self-organizing",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "node --import tsx server/index.ts",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "start:casc": "concurrently \"npm run server\" \"VITE_CASCBRIDGE=1 vite\"",
    "start:empire": "./start-empire.sh",
    "titan:web": "./start-titan-client.sh",
    "stack:check": "node tests/stack-browser-log.mjs",
    "test:stack:data": "node tests/inline-stack-data-validate.mjs",
    "verify:stack": "bash scripts/verify-stack.sh",
    "start:prod": "npm run build && serve -s dist -p 9120 --single",
    "casc:http": "node server/casc-http.cjs",
    "export:casc-samples": "node scripts/casc-export-samples.cjs",
    "triage:remastered-assets": "node scripts/remastered-asset-triage.cjs --pretty",
    "hunt:remastered-assets": "/usr/bin/node scripts/remastered-asset-hunt.cjs",
    "export:remastered-targets": "/usr/bin/node scripts/remastered-asset-export-targets.cjs",
    "analyze:startup-splash": "node scripts/analyze-startup-splash-assets.cjs",
    "analyze:campaign-race": "node scripts/analyze-campaign-race-screen.cjs",
    "analyze:unit-animations": "/usr/bin/node scripts/analyze-unit-animation-assets.cjs",
    "verify:unit-animation-stack": "/usr/bin/node scripts/verify-unit-animation-stack.cjs",
    "show:worker-carry": "/usr/bin/node scripts/capture-worker-carry-showcase.cjs",
    "build:screen-gallery": "/usr/bin/node scripts/build-remastered-screen-gallery.cjs",
    "rebuild:casclib": "cd node_modules/bw-casclib && CXXFLAGS=-Wno-narrowing npx node-gyp rebuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.0",
    "@react-three/postprocessing": "^2.16.2",
    "better-sqlite3": "^11.6.0",
    "bw-casclib": "^2.0.2",
    "express": "^4.21.0",
    "js-yaml": "^4.1.1",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
