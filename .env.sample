# Hermes x StarCraft local configuration.
# Copy to .env and update SC_ROOT before running `npm run start`.

# Your Hermes home directory. The bridge reads state.db, config.yaml, skills,
# cron jobs, logs, sessions, and API-key metadata from here.
HERMES_HOME=$HOME/.hermes

# Required: path to a local, legally owned StarCraft Remastered installation.
# Examples:
# SC_ROOT="/home/you/Games/battlenet/drive_c/Program Files (x86)/StarCraft"
# SC_ROOT="/mnt/c/Program Files (x86)/StarCraft"
SC_ROOT=

# Optional local ports.
CASC_PORT=8080
TITAN_STUB_RUNTIME_PORT=8090
TITAN_STUB_PLUGINS_PORT=8091

# Optional: override the packaged Titan renderer location.
# Leave blank to use ./packages/titan-reactor.
TITAN_ROOT=

# Optional: safer WebGL settings for VM/llvmpipe environments.
# TITAN_WEBGL_COMPAT=1
